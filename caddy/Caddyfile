{
    email admin@example.com
}

{$DOMAIN:localhost} {
    # Security Headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-XSS-Protection "1; mode=block"
    }

    # Rate limiting configuration (requires caddy-rate-limit plugin or can be done at app level)
    # Since standard Caddy doesn't have rate limiting built-in by default, 
    # we would need a custom build. For the scope of this assignment, 
    # rate_limit might not work out of the box without building Caddy with the module.
    # A workaround is to use Caddy's basic functionality or document that a custom build is needed.
    
    # Reverse Proxy to app
    reverse_proxy app:8000
}

# Optional Uptime Kuma proxy
status.{$DOMAIN:localhost} {
    reverse_proxy uptime-kuma:3001
}
